# Ignores specific to THIS repo only.
# Universal patterns (.DS_Store, vim swap, .env, etc.) live in
# .gitignore_global, which is wired up as core.excludesfile.

# Secret env sourced by .zshrc
.global.env

# asdf — ignored HERE only. Do NOT move to global: many projects
# legitimately commit .tool-versions and a global ignore would hide it.
.tool-versions

# binstubs
component/bin

.yarnrc.yml

# tmux plugins are tpm-managed at runtime; only tpm itself is tracked
tmux/*

# Tool state auto-written into the XDG dir (XDG_CONFIG_HOME=dotfiles/config)
config/configstore/

# gh stores auth tokens here after `gh auth login` — never commit
config/gh/hosts.yml
